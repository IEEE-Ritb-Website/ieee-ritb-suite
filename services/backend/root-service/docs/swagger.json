{
  "openapi": "3.0.0",
  "info": {
    "title": "IEEE RIT-B Root Service",
    "description": "Core public API microservice gateway for the IEEE Student Branch at RIT Bangalore. Provides chapter directory, user directory, and cron health-check endpoints.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api",
      "description": "API base path"
    }
  ],
  "paths": {
    "/chapters": {
      "get": {
        "tags": [
          "Chapters"
        ],
        "summary": "List IEEE chapters",
        "description": "Returns all IEEE chapters from the catalogue, with optional filtering by name, acronym, or type. Chapter logo URLs are generated dynamically via Cloudinary.",
        "operationId": "getChapters",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "Filter by chapter name (case-insensitive exact match)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "acronym",
            "in": "query",
            "description": "Filter by chapter acronym (case-insensitive exact match)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filter by chapter type",
            "schema": {
              "type": "string",
              "enum": [
                "tech",
                "non-tech"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success — list of chapters matching the filters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetChaptersSuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error — invalid query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Fatal internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/users": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "List IEEE users/members",
        "description": "Returns paginated list of IEEE members for the active term. Supports filtering by chapter affiliation, position type (senior/junior/execom), or specific position title. Chapters parameter accepts a comma-separated list of chapter names or acronyms.",
        "operationId": "getUsers",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of users to return (positive integer)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of users to skip for pagination (non-negative integer)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            }
          },
          {
            "name": "position",
            "in": "query",
            "description": "Filter by exact position title (case-insensitive). Ignored when onlySeniorPositions, onlyJuniorPositions, or onlyExecoms is set.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "chapters",
            "in": "query",
            "description": "Comma-separated list of chapter names or acronyms to filter by. All values must correspond to valid registered chapters.",
            "schema": {
              "type": "string"
            },
            "example": "WIE,CS"
          },
          {
            "name": "onlySeniorPositions",
            "in": "query",
            "description": "If true, filters for senior positions only (chair, vice-chair, secretary, treasurer, etc., excluding volunteers)",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "onlyJuniorPositions",
            "in": "query",
            "description": "If true, filters for junior/vice positions only (e.g., vice-chair, vice-secretary)",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "onlyExecoms",
            "in": "query",
            "description": "If true, filters for Execom members only",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success — paginated list of users",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetUsersSuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error — invalid query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Fatal internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cron": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Cron job health-check endpoint",
        "description": "Secured endpoint designed to be triggered by cron-job.org. Requires the x-cron-secret header to match the server's CRON_SECRET environment variable. Returns a timestamp and success message on valid invocation.",
        "operationId": "cronHandler",
        "parameters": [
          {
            "name": "x-cron-secret",
            "in": "header",
            "description": "Secret key for authenticating cron job requests. Must match the CRON_SECRET configured on the server.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cron job executed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CronSuccessResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized — invalid or missing x-cron-secret header",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Fatal internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": [
          "success",
          "error"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              false
            ]
          },
          "error": {
            "type": "object",
            "required": [
              "type",
              "message"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "validation",
                  "not_found",
                  "unauthorized",
                  "forbidden",
                  "fatal"
                ]
              },
              "message": {
                "type": "string"
              },
              "details": {
                "description": "Optional additional error details",
                "nullable": true
              }
            }
          }
        }
      },
      "Chapter": {
        "type": "object",
        "required": [
          "name",
          "type",
          "acronym",
          "shortDescription",
          "logoUrl"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Full name of the IEEE chapter"
          },
          "type": {
            "type": "string",
            "enum": [
              "tech",
              "non-tech"
            ],
            "description": "Chapter classification (technical or non-technical)"
          },
          "acronym": {
            "type": "string",
            "description": "Short acronym identifier for the chapter"
          },
          "shortDescription": {
            "type": "string",
            "description": "Brief description of the chapter's focus"
          },
          "logoUrl": {
            "type": "string",
            "description": "Cloudinary URL for the chapter's logo image"
          }
        }
      },
      "GetChaptersSuccessResponse": {
        "type": "object",
        "required": [
          "success",
          "data"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Chapter"
            }
          }
        }
      },
      "UserChapter": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the chapter the user belongs to"
          },
          "acronym": {
            "type": "string",
            "description": "Acronym of the chapter"
          },
          "position": {
            "type": "string",
            "description": "User's position/title within the chapter"
          }
        }
      },
      "User": {
        "type": "object",
        "required": [
          "name",
          "username",
          "chapters"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Full name of the user"
          },
          "image": {
            "type": "string",
            "nullable": true,
            "description": "URL to the user's profile image"
          },
          "username": {
            "type": "string",
            "description": "Unique username identifier"
          },
          "chapters": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserChapter"
            }
          },
          "department": {
            "type": "string",
            "nullable": true,
            "description": "Academic department"
          },
          "year": {
            "type": "string",
            "nullable": true,
            "description": "Current academic year"
          },
          "term": {
            "type": "string",
            "nullable": true,
            "description": "Active term identifier (e.g. '2026-27')"
          }
        }
      },
      "GetUsersSuccessResponse": {
        "type": "object",
        "required": [
          "success",
          "data"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          },
          "message": {
            "type": "string",
            "description": "Optional user-facing message"
          }
        }
      },
      "CronSuccessResponse": {
        "type": "object",
        "required": [
          "success",
          "data",
          "message"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "data": {
            "type": "object",
            "required": [
              "timestamp",
              "message"
            ],
            "properties": {
              "timestamp": {
                "type": "string",
                "description": "ISO 8601 timestamp of cron execution"
              },
              "message": {
                "type": "string",
                "description": "Status message confirming execution"
              }
            }
          },
          "message": {
            "type": "string",
            "description": "Top-level response message"
          }
        }
      }
    }
  }
}